# ============================================================
# YouTube Scraper & Translator — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- FFmpeg (optional, auto-detected if not set) ---
# Windows: C:\ffmpeg\bin\ffmpeg.exe
# Linux:   /usr/bin/ffmpeg
FFMPEG_PATH=

# --- Node.js (optional, required for yt-dlp JS rendering) ---
# Windows: C:\Program Files\nodejs\node.exe
NODE_PATH=

# --- Logging ---
LOG_LEVEL=INFO

# --- Video Processing ---
MIN_VIDEO_SIZE_MB=1.0
DEFAULT_VIDEO_QUALITY=1080

# --- Translation ---
SOURCE_LANGUAGE=en
TARGET_LANGUAGE=zh-CN

# --- AI Translation (GLM-4) ---
# Required for AI-powered subtitle optimization (--no-optimize is NOT set)
# Get your key at: https://open.bigmodel.cn/
GLM_API_KEY=

# --- Output Directories (relative to project root) ---
DOWNLOADS_DIR=downloads
SUBS_RAW_DIR=subs_raw
SUBS_TRANSLATED_DIR=subs_translated
OUTPUT_DIR=output
LOGS_DIR=logs
